# personal-rag — environment variable overrides
#
# Copy this file to .env and fill in your paths.
# .env is gitignored — never commit it.
#
# These variables override the corresponding paths in config.yaml without
# requiring any edits to the config file itself. Useful when the repo is
# shared across machines with different drive mount points.

# RAG_VAULT_PATH=/path/to/your/Obsidian Vault/
# RAG_PDF_BOOKS_PATH=/path/to/your/Books/
# RAG_PDF_RESOURCES_PATH=/path/to/your/Resources/
# RAG_JSON_PATH=/path/to/knowledge-base-index/indexed   # pre-extracted book/resource JSON
# RAG_INDEX_PATH=/data/chroma   # override ChromaDB storage path (set automatically in Docker)
# RAG_LOG_PATH=/data/logs/rag.log  # override app log file path (set automatically in Docker)
